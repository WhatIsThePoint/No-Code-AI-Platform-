# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=nocode
POSTGRES_PASSWORD=nocode_secret
POSTGRES_DB=nocode_auth
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Mongo ─────────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=nocode
MONGO_INITDB_ROOT_PASSWORD=nocode_secret
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=nocode_ingestion

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutes in seconds
JWT_REFRESH_TOKEN_EXPIRES=2592000   # 30 days in seconds

# ── Encryption (Fernet) ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-real-fernet-key

# ── Services (internal URLs used by API Gateway) ──────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
DATA_SERVICE_URL=http://data-ingestion-service:8002
ML_SERVICE_URL=http://ml-training-service:8003
METRICS_SERVICE_URL=http://metrics-service:8004

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_UPLOAD=10 per hour

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=/uploads
MAX_UPLOAD_SIZE_MB=100

# ── Model artifacts ───────────────────────────────────────────────────────────
MODEL_FOLDER=/models

# ── Email (MailHog in dev; configure real SMTP in prod) ───────────────────────
MAIL_SERVER=mailhog
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@nocode-ai.local
FRONTEND_URL=http://localhost:5173

# ── Stripe billing (leave empty to run without billing in dev) ────────────────
# Get your keys from https://dashboard.stripe.com/apikeys
# Test mode keys start with sk_test_ and pk_test_
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get webhook secret after running: stripe listen --forward-to localhost:8001/billing/webhook
STRIPE_WEBHOOK_SECRET=
# Price IDs from your Stripe dashboard (Products → Prices)
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_YEARLY=
STRIPE_PRICE_COMPANY_MONTHLY=
STRIPE_PRICE_COMPANY_YEARLY=

# ── Google OAuth (Meet + Calendar for company collab) ─────────────────────────
# Optional: if empty, /auth/google/* and /pipelines/<id>/meetings return
# 503 google_not_configured and the Meet button is disabled in the UI.
# Create an OAuth client at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must match GOOGLE_OAUTH_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Realtime SocketIO message queue (Redis DB 2 — avoids Celery DBs 0/1) ──────
SOCKETIO_MESSAGE_QUEUE=redis://redis:6379/2
