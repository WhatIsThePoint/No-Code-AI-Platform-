# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=nocode
POSTGRES_PASSWORD=nocode_secret
POSTGRES_DB=nocode_auth
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Mongo ─────────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=nocode
MONGO_INITDB_ROOT_PASSWORD=nocode_secret
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=nocode_ingestion

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRES=900        # 15 minutes in seconds
JWT_REFRESH_TOKEN_EXPIRES=2592000   # 30 days in seconds

# ── Encryption (Fernet) ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-real-fernet-key

# ── Services (internal URLs used by API Gateway) ──────────────────────────────
AUTH_SERVICE_URL=http://auth-service:8001
DATA_SERVICE_URL=http://data-ingestion-service:8002
ML_SERVICE_URL=http://ml-training-service:8003
METRICS_SERVICE_URL=http://metrics-service:8004

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATELIMIT_DEFAULT=100 per minute
RATELIMIT_UPLOAD=10 per hour

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=/uploads
MAX_UPLOAD_SIZE_MB=100

# ── Email (for invite notifications — stubbed in dev) ─────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@nocode-ai.local
