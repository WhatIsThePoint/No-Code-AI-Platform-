@startuml ch6_fig1
!include _style.iuml
left to right direction
title Sprint 3 use case --- Local RAG

actor "Authenticated user" as user

rectangle "RAG pipeline" {
  usecase "Open canvas in\nGenAI mode" as UC1
  usecase "Drop RAG starter\ntemplate" as UC2
  usecase "Upload document\n(PDF / DOCX / TXT)" as UC3
  usecase "Configure chunk size\nand top-k" as UC4
  usecase "Ingest --- chunk +\nembed + persist" as UC5
  usecase "Ask question" as UC6
  usecase "Stream answer\n(token by token)" as UC7
  usecase "View source chunks\n(similarity scores)" as UC8
  usecase "Open AI Companion" as UC9
}

user --> UC1
user --> UC2
user --> UC3
user --> UC4
user --> UC6
user --> UC9
UC3 ..> UC5 : <<includes>>
UC6 ..> UC7 : <<includes>>
UC7 ..> UC8 : <<extends>>
@enduml
