@startuml ch4_fig_seq_password_reset
!include _style.iuml
title Sequence --- password-reset round-trip via MailHog

actor User
participant "Browser" as ui
participant "api-gateway" as gw
participant "auth-service" as auth
database "Postgres\n(users)" as pg
participant "mail_service\n(smtplib)" as mail
participant "MailHog\n:1025 / :8025" as mh
database "Redis\n(refresh blacklist)" as redis

== Request ==
User -> ui : Forgot your password?\nenters email
ui -> gw : POST /auth/forgot-password
gw -> auth : forward (public prefix)
auth -> pg : SELECT WHERE LOWER(email)=LOWER(?)
alt user exists
  pg --> auth : user row
  auth -> auth : raw = secrets.token_urlsafe(32)
  auth -> pg : UPDATE password_reset_token_hash = sha256(raw),\n  password_reset_sent_at = NOW()
  auth -> mail : send_password_reset_email(link)
  mail -> mh : SMTP send (no-reply@nocode-ai.local)
end
auth --> ui : 200 if_account_exists_mail_sent\n(anti-enumeration; always 200)

== User clicks the link in MailHog UI ==
User -> mh : http://localhost:8025
mh --> User : email body with link
User -> ui : http://app/reset-password?token=<raw>

== Reset ==
User -> ui : enters new password twice
ui -> gw : POST /auth/reset-password\n{token, password}
gw -> auth : forward
auth -> pg : SELECT WHERE password_reset_token_hash = sha256(token)
alt token valid & age < 30 min
  auth -> auth : bcrypt.hash(new_password)
  auth -> pg : UPDATE password_hash, clear token + sent_at
  auth -> pg : UPDATE refresh_tokens SET revoked=true\nWHERE user_id = ?  (revoke EVERY session)
  auth --> ui : 200 {email, reset:true}
  ui --> User : "Password updated. Every session signed out."
else expired or unknown
  auth --> ui : 400 invalid_or_expired_token
  ui --> User : ask for a new link
end
@enduml
